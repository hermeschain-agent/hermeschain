# Hermeschain environment

NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgres://hermeschain:changeme@localhost:5432/hermeschain
REDIS_URL=redis://localhost:6379

# LLM backend — OpenRouter → Nous Hermes
OPENROUTER_API_KEY=sk-or-v1-...
HERMES_MODEL=nousresearch/hermes-4-405b
HERMES_BASE_URL=https://openrouter.ai/api/v1

# Chain
CHAIN_ID=1337

# Agent — model + rate controls
# HERMES_MODEL=claude-haiku-4-5-20251001       # override if a run needs Sonnet
# AGENT_MAX_ITERATIONS=5                        # iterations per task (was 10)
# AGENT_MAX_TOKENS=1200                         # per-call max_tokens
# AGENT_COMMIT_WINDOW_MINUTES=30                # floor between commits
# AGENT_HOUR_TOKEN_CAP=75000                    # pause if breached in rolling hour
# AGENT_DAY_TOKEN_CAP=500000                    # pause if breached in rolling UTC day

# Security
SESSION_SECRET=change-me-to-a-random-hex-string
CORS_ORIGINS=http://localhost:5173,https://hermeschain.app
