{
  "manifest_version": 3,
  "name": "Hermes Wallet",
  "version": "0.1.0",
  "description": "Self-custody wallet for Hermeschain — your keys, your coins. Keys are generated on-device and never sent to a server.",
  "action": { "default_popup": "popup.html", "default_title": "Hermes Wallet" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [{ "resources": ["inpage.js"], "matches": ["<all_urls>"] }],
  "permissions": ["storage"],
  "host_permissions": ["https://hermeschain.xyz/*", "https://*.hermeschain.xyz/*"]
}
